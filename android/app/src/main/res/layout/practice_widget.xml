<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="6dp">

    <!-- ===== Reminder state: warm orange→red (when 12h+ since practice) ===== -->
    <LinearLayout
        android:id="@+id/reminder_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_bg_reminder"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="14dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_widget_pick"
            android:contentDescription="@string/widget_description" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time to practice!"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/reminder_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="0m total"
                android:textColor="#FFE6DC"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===== Normal state: dark card showing lifetime practice time ===== -->
    <LinearLayout
        android:id="@+id/normal_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_bg_normal"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="14dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_widget_pick"
            android:tint="#FF8A3D"
            android:contentDescription="@string/widget_description" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/total_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0m"
                android:textColor="#FF8A3D"
                android:textStyle="bold"
                android:textSize="30sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="practised"
                android:textColor="#9FB0C3"
                android:textSize="12sp"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/ok_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:textColor="#6E7B8C"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
